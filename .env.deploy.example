# Modelo de credenciais de deploy via FTP.
# Copie para .env.deploy e preencha com os valores reais:
#   cp .env.deploy.example .env.deploy
DEPLOY_HOST=00.00.00.00
DEPLOY_PORT=21
DEPLOY_USER=usuario_ftp
# Use aspas simples se a senha tiver caracteres especiais (#, *, [, etc.)
DEPLOY_PASS='sua_senha_ftp'
# Caminho da pasta do tema no servidor (caminho absoluto na Hostinger):
DEPLOY_REMOTE_DIR=/domains/SEU-DOMINIO.com.br/public_html/wp-content/themes/reloadse-child
